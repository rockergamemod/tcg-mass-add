{
  "name": "backend",
  "root": "backend",
  "sourceRoot": "backend/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run build", "cwd": "backend" }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run start", "cwd": "backend" }
    },
    "start:dev": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run start:dev", "cwd": "backend" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run lint", "cwd": "backend" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run test", "cwd": "backend" }
    }
  },
  "tags": []
}
